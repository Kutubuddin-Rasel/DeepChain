# Application
NODE_ENV=development
PORT=3001

# Database (matches docker-compose.yml)
DATABASE_URL="postgresql://foodio:foodio_secret@localhost:5432/foodio_db?schema=public"

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT
JWT_SECRET=foodio_jwt_super_secret_key_change_in_production
JWT_EXPIRATION=7d

# Cloudinary (fill in your credentials)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# CORS
FRONTEND_URL=http://localhost:3000
